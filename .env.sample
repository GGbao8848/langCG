OLLAMA_URL=http://192.168.1.231:11434

OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=openrouter/free
OPENROUTER_MODELS=openrouter/free,openrouter/auto,google/gemini-2.5-flash
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Agent 文件系统工具默认只访问这些目录，多目录用英文逗号分隔。
LANGCG_FILESYSTEM_ROOTS=data/filesystem_workspace
# 如需启用删除，可把 file_delete 加到工具列表中
LANGCG_FILESYSTEM_TOOLS=read_file,write_file,list_directory,file_search,copy_file,move_file

# 远端增量数据发布 / 远端 last_yaml 读取默认走这里的 SFTP / SSH 配置
REMOTE_SFTP_HOST=172.31.1.42
REMOTE_SFTP_USERNAME=your_name
REMOTE_SFTP_PRIVATE_KEY_PATH=/home/qzq/.ssh/id_ed25519
REMOTE_SFTP_PORT=22
