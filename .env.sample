OLLAMA_URL=http://192.168.1.231:11434

OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=openrouter/free
OPENROUTER_MODELS=openrouter/free,openrouter/auto,google/gemini-2.5-flash
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# LangChain agent middleware。可选：
# model_retry,tool_retry,model_call_limit,tool_call_limit,context_editing,summarization,tool_selector,openai_moderation
LANGCG_AGENT_MIDDLEWARE=model_retry,context_editing,tool_call_limit
LANGCG_MODEL_RETRY_MAX_RETRIES=4
LANGCG_TOOL_CALL_RUN_LIMIT=80

# context_editing 会在上下文过长时清理旧工具结果，减少 token 膨胀。
LANGCG_CONTEXT_EDITING_TRIGGER=24000
LANGCG_CONTEXT_EDITING_CLEAR_AT_LEAST=4000
LANGCG_CONTEXT_EDITING_KEEP=3
LANGCG_CONTEXT_EDITING_CLEAR_TOOL_INPUTS=false

# summarization 会在长对话中压缩历史消息；默认复用当前聊天模型。
LANGCG_SUMMARIZATION_TRIGGER_TYPE=tokens
LANGCG_SUMMARIZATION_TRIGGER_VALUE=24000
LANGCG_SUMMARIZATION_KEEP_TYPE=messages
LANGCG_SUMMARIZATION_KEEP_VALUE=20

# tool_selector 会先筛选相关工具，工具很多时可减少工具定义 token。
# LANGCG_TOOL_SELECTOR_MAX_TOOLS=8

# 启用 openai_moderation 时需要 OPENAI_API_KEY，审核接口走 OpenAI moderation endpoint。
# OPENAI_API_KEY=your_openai_api_key
LANGCG_OPENAI_MODERATION_MODEL=omni-moderation-latest
LANGCG_OPENAI_MODERATION_CHECK_INPUT=true
LANGCG_OPENAI_MODERATION_CHECK_OUTPUT=true
LANGCG_OPENAI_MODERATION_CHECK_TOOL_RESULTS=false
LANGCG_OPENAI_MODERATION_EXIT_BEHAVIOR=end

# Agent 文件系统工具默认只访问这些目录，多目录用英文逗号分隔。
LANGCG_FILESYSTEM_ROOTS=data/filesystem_workspace
# 如需启用删除，可把 file_delete 加到工具列表中
LANGCG_FILESYSTEM_TOOLS=read_file,write_file,list_directory,file_search,copy_file,move_file

# 远端增量数据发布 / 远端 last_yaml 读取默认走这里的 SFTP / SSH 配置
REMOTE_SFTP_HOST=172.31.1.42
REMOTE_SFTP_USERNAME=your_name
REMOTE_SFTP_PRIVATE_KEY_PATH=/home/qzq/.ssh/id_ed25519
REMOTE_SFTP_PORT=22
